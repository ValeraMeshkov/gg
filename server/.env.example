# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Случайная строка ≥32 символов (подпись JWT-сессии)
AUTH_SESSION_SECRET=

# Куда вернуть браузер после входа
FRONTEND_URL=http://localhost:5174

# Публичный URL API для redirect_uri Google (в dev — через прокси Vite)
PUBLIC_API_URL=http://localhost:5174
GOOGLE_REDIRECT_URI=http://localhost:5174/api/auth/google/callback

